# =============================================================================
# Bland AI Call Analysis - Environment Variables
# =============================================================================
#
# 1. Copy this file to .env:
#       cp .env.example .env
#
# 2. Replace the placeholder values below with your actual credentials.
#
# 3. NEVER commit your .env file to version control. Add it to .gitignore.
# =============================================================================

# Your Bland AI API key.
# Find it in the Bland dashboard: Settings > API Keys
# It typically starts with "sk-"
BLAND_API_KEY=sk-your-api-key-here

# The phone number to call for the call_with_citations.py example.
# Must be in E.164 format: + followed by country code and number, no spaces.
# Example: +15551234567
PHONE_NUMBER=+15551234567

# Optional: Your SMS-configured Bland phone number for sending follow-up texts.
# Used by call_with_citations.py to send an SMS confirmation after a call.
# If not set, the SMS follow-up step is skipped.
# FROM_NUMBER=+15559876543

# Port for the webhook listener server.
# The webhook_listener.py script uses this to set the listening port.
# Default is 3000 if not specified.
PORT=3000
