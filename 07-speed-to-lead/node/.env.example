# =============================================================================
# Bland AI Speed to Lead - Environment Variables (Node.js)
# =============================================================================
#
# 1. Copy this file and rename it to ".env" in the same folder:
#        cp .env.example .env
#
# 2. Replace the placeholder values below with your real credentials.
#
# 3. You can find your Bland AI API key at https://app.bland.ai under the
#    developer portal (Settings > API Keys).
#
# IMPORTANT: Never commit your real .env file to version control.
#            The .env file is listed in .gitignore for this reason.
# =============================================================================

# Your Bland AI API key. This authenticates every request to the Bland API.
# It typically starts with "sk-".
BLAND_API_KEY=sk-your-api-key-here

# The public URL where Bland sends post-call results (transcript, summary, etc.)
# when a call finishes. This must be accessible from the internet.
#
# For local testing, use ngrok to expose your local server:
#   ngrok http 3000
# Then paste the HTTPS URL here, e.g.:
#   https://abc123.ngrok.io/webhook/call-complete
WEBHOOK_URL=https://your-server.com/webhook/call-complete

# Default phone number for transferring qualified leads to a live sales rep.
# Must be in E.164 format (e.g., +15559876543).
TRANSFER_NUMBER=+15559876543

# Dedicated sales line for the transfer list.
# The AI agent routes to this number when the lead has a sales inquiry.
SALES_NUMBER=+15559876543

# Dedicated support line for the transfer list.
# The AI agent routes to this number when the lead has a support question.
SUPPORT_NUMBER=+15551112222

# Your company name, used in the qualification prompt and voicemail message.
COMPANY_NAME=Acme Corp

# The port the Express server listens on. Defaults to 3000 if not set.
PORT=3000
