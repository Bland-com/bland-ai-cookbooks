# =============================================================================
# Bland AI Batch Campaigns - Environment Variables
# =============================================================================
#
# 1. Copy this file to .env:
#       cp .env.example .env
#
# 2. Replace the placeholder values below with your actual credentials.
#
# 3. NEVER commit your .env file to version control. Add it to .gitignore.
# =============================================================================

# Your Bland AI API key.
# Find it in the Bland dashboard: Settings > API Keys
# It typically starts with "sk-"
BLAND_API_KEY=your-api-key-here

# Path to the CSV file containing your contact list.
# Each row becomes one call in the batch.
# The CSV must include a "phone_number" column.
# All other column names become template variables (e.g., {{patient_name}}).
CSV_FILE_PATH=sample_leads.csv

# (Optional) A webhook URL that receives batch lifecycle status updates.
# Bland will POST to this URL as the batch progresses through each stage:
# validating, dispatching, in_progress, completed, failed, etc.
# Leave blank or comment out if you do not need webhook notifications.
# STATUS_WEBHOOK=https://your-server.com/api/batch-status
