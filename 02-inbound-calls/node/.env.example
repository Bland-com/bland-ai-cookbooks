# =============================================================================
# Bland AI Inbound Calls - Environment Variables
# =============================================================================
#
# 1. Copy this file and rename it to ".env" in the same folder.
# 2. Replace the placeholder below with your real Bland AI API key.
# 3. You can find your API key at https://app.bland.ai under the developer portal.
#
# This key is used to authenticate every request to the Bland API.
# Keep it secret. Never commit your real .env file to version control.
# =============================================================================

BLAND_API_KEY=sk-your-api-key-here
