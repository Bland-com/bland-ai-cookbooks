# Bland AI API key. Found in the Bland dashboard under Settings > API Keys.
BLAND_API_KEY=sk-your-api-key-here

# The phone number to call, in E.164 format (e.g., +15551234567).
# Use your own phone number for testing.
PHONE_NUMBER=+15551234567

# The public URL of your calendar server. During local development,
# this is your ngrok forwarding URL (e.g., https://abc123.ngrok-free.app).
# Bland's servers cannot reach localhost, so you must use ngrok or deploy
# the calendar server to a public host.
CALENDAR_SERVER_URL=https://your-ngrok-url.ngrok-free.app

# An authorization key for your calendar server. This is sent in the
# Authorization header of every tool request. Choose any string you like,
# and make sure it matches the CALENDAR_AUTH_KEY in your calendar server.
CALENDAR_AUTH_KEY=test-calendar-key

# The port the calendar server listens on. Default is 5100.
CALENDAR_SERVER_PORT=5100
