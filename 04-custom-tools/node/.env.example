# Your Bland AI API key. Find it in the dashboard under Settings > API Keys.
# It usually starts with "sk-".
BLAND_API_KEY=sk-your-api-key-here

# The phone number to call for testing. Must be in E.164 format.
# Example: +15551234567 (US number with country code).
# Use your own mobile number so you can answer and test the tools.
PHONE_NUMBER=+15551234567

# The public URL where your webhook server is reachable.
# If running locally, use ngrok to create a tunnel:
#   ngrok http 3001
# Then paste the HTTPS URL here (e.g., https://abc123.ngrok.io).
# Do NOT include a trailing slash.
# Do NOT include the endpoint path, just the base URL.
WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# (Optional) The port your webhook server listens on. Default is 3001.
PORT=3001
