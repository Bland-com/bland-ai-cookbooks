# Bland AI API Key
# Get yours from https://app.bland.ai under Developer settings
BLAND_API_KEY=sk-your-api-key-here

# Pathway ID
# You get this after running create_pathway.py, or from the Bland dashboard.
# Leave blank until you have created a pathway.
PATHWAY_ID=

# Phone Number
# The phone number to call when running send_call_with_pathway.py.
# Must be in E.164 format with country code (e.g., +12223334444).
PHONE_NUMBER=+1XXXXXXXXXX
