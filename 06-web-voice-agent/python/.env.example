# Your Bland AI API key.
# Find this in the Bland dashboard under Settings > API Keys.
# This key authenticates all requests to the Bland API.
# Keep it secret and never expose it in frontend code.
BLAND_API_KEY=sk-your-api-key-here

# Your Web Agent ID.
# This is returned when you run create_agent.py.
# It identifies which agent configuration to use for sessions.
# Leave this blank until you have created an agent.
BLAND_AGENT_ID=
