# =============================================================================
# Bland AI - SMS Messaging - Environment Variables
# =============================================================================
#
# 1. Copy this file to .env:
#       cp .env.example .env
#
# 2. Replace the placeholder values below with your actual credentials.
#
# 3. NEVER commit your .env file to version control. Add it to .gitignore.
# =============================================================================

# Your Bland AI API key.
# Find it in the Bland dashboard: Settings > API Keys
# It typically starts with "sk-"
BLAND_API_KEY=sk-your-api-key-here

# The phone number to send SMS messages from.
# This must be a Bland phone number that has been configured for SMS
# in your Bland dashboard. It can be the same number you use for voice calls.
# Must be in E.164 format: + followed by country code and number, no spaces.
# Example: +15551234567
FROM_NUMBER=+15551234567

# The recipient's phone number.
# This is the person who will receive your text messages.
# Must be in E.164 format: + followed by country code and number, no spaces.
# Example: +15559876543
TO_NUMBER=+15559876543
